{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "deny": [
      "Read(**/.env)",
      "Read(**/.env.*)",
      "Read(**/target.json)",
      "Read(**/*id_rsa*)",
      "Read(**/*id_ed25519*)",
      "Read(**/*credentials*)",
      "Read(**/*token*)",
      "Bash(powershell:*)",
      "Bash(powershell.exe:*)"
    ],
    "allow": [
      "WebSearch",
      "WebFetch",
      "mcp__context7__*",
      "mcp__github__*",
      "mcp__microsoft-learn__*",
      "mcp__playwright__*",
      "mcp__web-search-prime__*",
      "mcp__web_reader__*",
      "mcp__zread__*"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash|Read",
        "hooks": [
          {
            "type": "command",
            "shell": "powershell",
            "command": "python (Join-Path $env:CLAUDE_PROJECT_DIR '.claude/hooks/governed-pre-tool-use.py')",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
