{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "QuestionExtractionResult",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "source_document_id",
    "questions",
    "warnings"
  ],
  "properties": {
    "source_document_id": {
      "type": "string"
    },
    "questions": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "local_number",
          "question_type",
          "stem_blocks",
          "options",
          "sub_questions",
          "answer",
          "solution",
          "source_regions",
          "confidence",
          "review_required",
          "issues"
        ],
        "properties": {
          "local_number": {
            "type": "string"
          },
          "question_type": {
            "type": "string"
          },
          "stem_blocks": {
            "type": "array",
            "items": {
              "type": "object",
              "required": [
                "type",
                "content",
                "confidence"
              ],
              "additionalProperties": true,
              "properties": {
                "type": {
                  "type": "string",
                  "enum": [
                    "text",
                    "formula",
                    "image",
                    "table",
                    "chart",
                    "shared_material_ref"
                  ]
                },
                "content": {
                  "type": [
                    "string",
                    "object",
                    "null"
                  ]
                },
                "confidence": {
                  "type": "number",
                  "minimum": 0,
                  "maximum": 1
                }
              }
            }
          },
          "options": {
            "type": "array",
            "items": {
              "type": "object",
              "required": [
                "label",
                "blocks"
              ],
              "additionalProperties": true,
              "properties": {
                "label": {
                  "type": "string"
                },
                "blocks": {
                  "type": "array"
                }
              }
            }
          },
          "sub_questions": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": true
            }
          },
          "answer": {
            "type": [
              "string",
              "null"
            ]
          },
          "solution": {
            "type": [
              "string",
              "null"
            ]
          },
          "source_regions": {
            "type": "array",
            "items": {
              "type": "object",
              "required": [
                "page",
                "bbox"
              ],
              "properties": {
                "page": {
                  "type": "integer"
                },
                "bbox": {
                  "type": "array",
                  "items": {
                    "type": "number"
                  },
                  "minItems": 4,
                  "maxItems": 4
                }
              }
            }
          },
          "confidence": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          },
          "review_required": {
            "type": "boolean"
          },
          "issues": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    },
    "warnings": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
