{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "AiSuggestionEnvelope",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "suggestion_type",
    "source",
    "confidence",
    "review",
    "cost",
    "cache",
    "payload"
  ],
  "properties": {
    "suggestion_type": {
      "type": "string",
      "enum": [
        "knowledge_tagging",
        "question_type",
        "difficulty_estimation",
        "answer_verification"
      ]
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source_document_id",
        "source_region_ids",
        "model_route",
        "prompt_version"
      ],
      "properties": {
        "source_document_id": {
          "type": "string"
        },
        "source_region_ids": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "model_route": {
          "type": "string"
        },
        "prompt_version": {
          "type": "string"
        }
      }
    },
    "confidence": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "score",
        "threshold"
      ],
      "properties": {
        "score": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "threshold": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        }
      }
    },
    "review": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "required",
        "status",
        "review_queue_id"
      ],
      "properties": {
        "required": {
          "type": "boolean"
        },
        "status": {
          "type": "string",
          "enum": [
            "pending_review",
            "approved",
            "rejected"
          ]
        },
        "review_queue_id": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "cost": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "input_tokens",
        "output_tokens",
        "estimated_usd"
      ],
      "properties": {
        "input_tokens": {
          "type": "number",
          "minimum": 0
        },
        "output_tokens": {
          "type": "number",
          "minimum": 0
        },
        "estimated_usd": {
          "type": "number",
          "minimum": 0
        }
      }
    },
    "cache": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "cache_key",
        "cache_hit"
      ],
      "properties": {
        "cache_key": {
          "type": "string"
        },
        "cache_hit": {
          "type": "boolean"
        }
      }
    },
    "payload": {
      "type": "object"
    }
  }
}
