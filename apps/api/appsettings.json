{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "KqgPaths": {
    "DataRoot": "D:\\KQG_Data",
    "FileStoreRoot": "D:\\KQG_Data\\file_store",
    "BackupRoot": "D:\\KQG_Backups",
    "LogsRoot": "D:\\KQG_Data\\logs"
  },
  "ConnectionStrings": {
    "KqgDatabase": "Host=127.0.0.1;Port=5432;Database=k12_question_graph;Username=postgres"
  },
  "PythonWorker": {
    "PythonExecutable": "python",
    "DocumentWorkerScript": "workers\\document\\worker.py",
    "TimeoutSeconds": 20
  },
  "AiRouting": {
    "Version": "d001.draft-test.v1",
    "AllowRealModelCalls": false,
    "DefaultMode": "balanced",
    "PromptVersion": "prompt.d001.draft-test.v1",
    "Routes": {
      "file_dedup": {
        "Handler": "rule"
      },
      "question_extraction": {
        "Handler": "llm",
        "ModelTier": "medium",
        "StructuredOutputSchema": "schemas/ai/question_extraction.schema.json",
        "RequireHumanReviewBelowConfidence": 0.85
      },
      "knowledge_tagging": {
        "Handler": "llm",
        "ModelTier": "small_or_medium",
        "StructuredOutputSchema": "schemas/ai/knowledge_mapping.schema.json",
        "RequireHumanReviewBelowConfidence": 0.8,
        "Batchable": true
      },
      "natural_language_paper_request": {
        "Handler": "llm",
        "ModelTier": "medium",
        "StructuredOutputSchema": "schemas/ai/natural_language_paper_request.schema.json",
        "RequireHumanReviewBelowConfidence": 0.85
      },
      "answer_verification": {
        "Handler": "llm",
        "ModelTier": "medium_or_strong",
        "StructuredOutputSchema": "schemas/ai/answer_verification.schema.json",
        "RequireHumanReviewBelowConfidence": 0.9
      }
    }
  },
  "AllowedHosts": "*"
}
