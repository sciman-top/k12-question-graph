{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AdminInternalGuard": {
    "ApiKey": "",
    "AllowUnguardedDraftTest": true
  },
  "AdminInternalRoleAudit": {
    "Enabled": true,
    "RequireRoleHeader": true,
    "RequireOperatorIdHeader": true,
    "EnableAuditLog": true,
    "AuditLogFileName": "admin-internal-audit.jsonl"
  },
  "PythonWorker": {
    "DocumentWorkerScript": "..\\..\\workers\\document\\worker.py"
  }
}
