# Development-only bootstrap for local K12 Question Graph runs.
# Runtime truth priority:
# 1. Admin UI saved local encrypted settings under D:\KQG_Data\config\admin\
# 2. Process environment variables
# 3. This root .env file, loaded only by local start scripts
#
# Recommended naming below is the current contract.
# Legacy names such as TEXT_PROVIDER_* / IMAGE_PROVIDER_* remain bootstrap-compatible
# for now, but new local configs should migrate to KQG_AI_* names.

# Primary OpenAI-compatible provider
KQG_AI_OPENAI_BASE_URL=https://api.openai.com/v1
KQG_AI_OPENAI_KEY=

# Optional image override
# Leave these blank to reuse the primary base URL and key.
KQG_AI_IMAGE_OPENAI_BASE_URL=
KQG_AI_IMAGE_OPENAI_KEY=

# Web -> API local route
VITE_KQG_API_BASE_URL=http://127.0.0.1:5275
